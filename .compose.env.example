# Copy this file to .compose.env and fill in your values.
# Used by compose.yaml via env_file: .compose.env

# Port the Node.js app listens on inside the container
PORT=3000

# MongoDB connection URI (used by labs-web)
MONGO_URI=mongodb://admin:changeme@mongo:27017/labsweb?authSource=admin

# MongoDB root credentials (used by the mongo service and mongo-express)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# mongo-express web UI credentials
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=changeme
ME_CONFIG_MONGODB_URL=mongodb://admin:changeme@mongo:27017/
ME_CONFIG_BASICAUTH=true
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=changeme
