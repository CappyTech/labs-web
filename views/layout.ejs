<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Cappy Labs' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Cappy Labs — a home for small experiments and self-hosted projects.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <%# CDN must load first so tailwind global exists before config is set %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: '#0e1a1f',
            surface: { DEFAULT: '#14252c', 2: '#193037' },
            ink: '#dde9e7',
            muted: '#6f8d90',
            hairline: 'rgba(255,255,255,0.08)',
            accent: '#e8a13c',
            signal: '#5fb8c4',
            settled: '#7ecb7e',
          },
          fontFamily: {
            display: ['"Space Grotesk"', 'system-ui', 'sans-serif'],
            mono: ['"IBM Plex Mono"', 'ui-monospace', 'monospace'],
          },
          animation: { led: 'led 2.6s ease-in-out infinite' },
          keyframes: {
            led: { '0%, 100%': { opacity: '1' }, '50%': { opacity: '0.35' } },
          },
        },
      },
    }
  </script>

  <%# Component styles in a plain <style> tag — no @apply, no timing dependency on Tailwind config %>
  <style>
    /* ── Reset ───────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Body / page chrome ──────────────────────────────────────── */
    body {
      background-color: #0e1a1f;
      color: #dde9e7;
      font-family: "Space Grotesk", system-ui, sans-serif;
      line-height: 1.5;
      min-height: 100vh;
      background-image:
        linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px),
        radial-gradient(ellipse at 50% -10%, rgba(95,184,196,0.06), transparent 60%);
      background-size: 48px 48px, 48px 48px, 100% 100%;
    }

    h1 {
      font-weight: 700;
      letter-spacing: -0.03em;
      font-size: clamp(44px, 9vw, 88px);
      line-height: 0.96;
    }

    /* ── Form elements ───────────────────────────────────────────── */
    input[type="text"],
    input[type="number"],
    input[type="date"],
    textarea,
    select {
      background-color: #0e1a1f;
      border: 1px solid rgba(255,255,255,0.08);
      color: #dde9e7;
      border-radius: 4px;
      padding: 6px 10px;
      font-size: 13px;
      font-family: "IBM Plex Mono", ui-monospace, monospace;
    }
    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="date"]:focus,
    textarea:focus,
    select:focus { outline: none; border-color: rgba(95,184,196,0.5); }
    input[type="checkbox"] { accent-color: #5fb8c4; width: 16px; height: 16px; cursor: pointer; }

    /* ── Tables ──────────────────────────────────────────────────── */
    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left;
      padding: 4px 8px;
      font-size: 11px;
      opacity: 0.6;
      font-family: "IBM Plex Mono", monospace;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    td { padding: 4px 8px; font-size: 13px; }

    /* ── LED pulse ───────────────────────────────────────────────── */
    @keyframes led { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
    .animate-led { animation: led 2.6s ease-in-out infinite; }

    /* ── Layout atoms ────────────────────────────────────────────── */
    .wrap { max-width: 920px; margin: 0 auto; padding: 0 24px; }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }

    /* ── Hero ────────────────────────────────────────────────────── */
    .hero { padding: 76px 0 40px; }

    .eyebrow {
      font-family: "IBM Plex Mono", ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: #e8a13c;
      margin-bottom: 18px;
    }
    .eyebrow a { color: #e8a13c; text-decoration: none; }
    .eyebrow a:hover { opacity: 0.75; }

    .lede { margin-top: 20px; max-width: 46ch; color: #6f8d90; font-size: 17px; }

    /* ── Section label ───────────────────────────────────────────── */
    .section-label {
      display: flex;
      align-items: baseline;
      gap: 14px;
      font-family: "IBM Plex Mono", ui-monospace, monospace;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #6f8d90;
      margin-top: 40px;
      margin-bottom: 16px;
    }
    .section-label::after {
      content: "";
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.08);
    }

    /* ── Module card ─────────────────────────────────────────────── */
    .module {
      position: relative;
      display: block;
      text-decoration: none;
      color: #dde9e7;
      background: #14252c;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 20px;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }
    .module:hover, .module:focus-visible {
      transform: translateY(-3px);
      border-color: rgba(232,161,60,0.5);
      background: #193037;
      outline: none;
    }
    .module:focus-visible { box-shadow: 0 0 0 2px #e8a13c; }
    .module .callsign {
      font-family: "IBM Plex Mono", monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      color: #5fb8c4;
    }
    .module .name { margin-top: 10px; font-size: 21px; font-weight: 500; letter-spacing: -0.01em; }
    .module .desc { margin-top: 6px; font-size: 14px; color: #6f8d90; }
    .module .host {
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: "IBM Plex Mono", monospace;
      font-size: 12px;
      color: #6f8d90;
    }
    .module .arrow { margin-left: auto; color: #e8a13c; transition: transform 0.18s ease; }
    .module:hover .arrow { transform: translateX(3px); }

    /* ── Button ──────────────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      font-size: 11px;
      font-family: "IBM Plex Mono", ui-monospace, monospace;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background-color: #193037;
      border: 1px solid rgba(255,255,255,0.08);
      color: #dde9e7;
      border-radius: 4px;
      text-decoration: none;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn:hover { border-color: rgba(232,161,60,0.5); color: #e8a13c; }

    /* ── Status badge ────────────────────────────────────────────── */
    .status-badge {
      font-family: "IBM Plex Mono", monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 4px;
      background: #193037;
      color: #6f8d90;
    }
    .status-badge.status-pending  { color: #e8a13c; }
    .status-badge.status-computed { color: #5fb8c4; }
    .status-badge.status-settled  { color: #7ecb7e; }

    /* ── Utility ─────────────────────────────────────────────────── */
    .empty-state { color: #6f8d90; font-family: "IBM Plex Mono", monospace; font-size: 13px; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation: none !important; transition: none !important; }
    }
  </style>
</head>
<body>

  <div class="sticky top-0 z-10 border-b border-hairline bg-bg/60 backdrop-blur-sm">
    <div class="wrap flex items-center gap-3 h-11 font-mono text-xs tracking-[0.04em] text-muted">
      <span class="w-2 h-2 rounded-full bg-signal shadow-[0_0_8px_#5fb8c4] animate-led" aria-hidden="true"></span>
      <span>STATION&nbsp;CAPPYLABS.UK</span>
      <span class="opacity-40" aria-hidden="true">·</span>
      <span>NODE ONLINE</span>
      <span class="ml-auto text-ink" id="clock">--:--:--</span>
    </div>
  </div>

  <%- body %>

  <div class="wrap">
    <footer class="border-t border-hairline pt-5 pb-10 mt-16 font-mono text-xs text-muted flex gap-2.5 flex-wrap">
      <span>cappylabs.uk</span>
      <span class="opacity-40">·</span>
      <span>built &amp; broken by cappy</span>
      <span class="opacity-40">·</span>
      <span id="year"></span>
      <span class="opacity-40">·</span>
      <span>v<%= appVersion %></span>
    </footer>
  </div>

  <script>
    const clock = document.getElementById('clock');
    function tick() {
      clock.textContent = new Date().toLocaleTimeString('en-GB', { timeZone: 'Europe/London' });
    }
    tick(); setInterval(tick, 1000);
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>

</body>
</html>
