  <div class="wrap">
    <header class="hero">
      <div class="eyebrow">Milk-round bill splitter</div>
      <h1>Milk<span class="text-accent">·</span>Man</h1>
      <p class="lede">Track invoices, allocation rules, and per-member splits for the milk round.</p>
    </header>

    <div class="section-label">Manage</div>
    <section class="card-grid mb-8">
      <a href="/milkman/invoices" class="module">
        <div class="callsign">[NAV]</div>
        <div class="name">Invoices</div>
        <div class="desc">Create and manage invoices</div>
      </a>
      <a href="/milkman/members" class="module">
        <div class="callsign">[NAV]</div>
        <div class="name">Members</div>
        <div class="desc">Add or edit members</div>
      </a>
      <a href="/milkman/products" class="module">
        <div class="callsign">[NAV]</div>
        <div class="name">Products</div>
        <div class="desc">Manage milk-round products</div>
      </a>
      <a href="/milkman/rules" class="module">
        <div class="callsign">[NAV]</div>
        <div class="name">Allocation Rules</div>
        <div class="desc">Define who pays for what</div>
      </a>
      <a href="/milkman/settlements" class="module">
        <div class="callsign">[NAV]</div>
        <div class="name">Settlements</div>
        <div class="desc">View payment summaries</div>
      </a>
    </section>

    <div class="section-label">Recent invoices</div>
    <section class="card-grid mb-8">
      <% if (recentInvoices.length === 0) { %>
        <p class="empty-state">No invoices yet.</p>
      <% } else { %>
        <% recentInvoices.forEach(function(inv) { %>
        <a href="/milkman/invoices/<%= inv.id %>" class="module">
          <div class="callsign">[<%= inv.number %>]</div>
          <div class="name"><%= inv.total %></div>
          <div class="desc"><%= inv.receiptDateFormatted %></div>
          <div class="host">
            <span class="status-badge status-<%= inv.status %>"><%= inv.status %></span>
          </div>
        </a>
        <% }); %>
      <% } %>
    </section>

    <div class="section-label">Members</div>
    <section class="card-grid pb-16">
      <% if (members.length === 0) { %>
        <p class="empty-state">No members yet.</p>
      <% } else { %>
        <% members.forEach(function(m) { %>
        <div class="module">
          <div class="callsign">[MEMBER]</div>
          <div class="name"><%= m.name %></div>
          <% if (m.isBuyer) { %>
          <div class="desc">account holder</div>
          <% } %>
        </div>
        <% }); %>
      <% } %>
    </section>
  </div>
