  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/invoices">Invoices</a></div>
      <h1>New invoice</h1>
      <p class="lede">Enter the invoice header. Add delivery days and line items after saving.</p>
    </header>

    <div class="flex gap-3 mb-8">
      <a href="/milkman/invoices/parse" class="btn">Paste invoice text instead →</a>
    </div>

    <form method="POST" action="/milkman/invoices" class="max-w-sm">
      <div class="flex flex-col gap-4 pb-16">
        <label class="flex flex-col gap-1">
          Invoice number
          <input type="text" name="number" required placeholder="e.g. 39875277">
        </label>
        <label class="flex flex-col gap-1">
          Receipt date
          <input type="date" name="receiptDate" required>
        </label>
        <label class="flex flex-col gap-1">
          Transaction ID (optional)
          <input type="text" name="transactionId" placeholder="e.g. TXN-001">
        </label>
        <label class="flex flex-col gap-1">
          Invoice total (pence)
          <input type="number" name="totalP" required min="0" step="1" placeholder="e.g. 1250">
          <small class="text-muted font-mono text-[11px]">Enter the grand total as shown on the invoice in pence (e.g. £12.50 → 1250).</small>
        </label>
        <div class="flex gap-3">
          <button type="submit" class="btn">Create invoice</button>
          <a href="/milkman/invoices" class="btn">Cancel</a>
        </div>
      </div>
    </form>
  </div>
