  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/invoices/parse">Parse</a></div>
      <h1>Review parsed invoice</h1>
      <p class="lede">Check product and member assignments, then create the invoice.</p>
    </header>

    <form method="POST" action="/milkman/invoices/confirm">

      <input type="hidden" name="kind" value="<%= parsed.kind || 'delivery' %>">

      <%# ── Duplicate warning ──────────────────────────────────────────── %>
      <% if (duplicate) { %>
      <div class="mb-6 p-4 rounded" style="background:#3a1f0a;border:1px solid #e8a13c;">
        <p class="text-accent font-semibold mb-1">&#9888; Invoice #<%= duplicate.number %> already exists</p>
        <p class="text-muted text-sm">
          Received <%= duplicate.date %> &nbsp;·&nbsp;
          <span class="status-badge status-<%= duplicate.status %>"><%= duplicate.status %></span>
          &nbsp;·&nbsp;
          <a href="/milkman/invoices/<%= duplicate.id %>" class="text-signal underline">View existing invoice</a>
        </p>
        <p class="text-muted text-sm mt-2">Creating this invoice will fail. Go back and re-paste a different invoice, or view the existing one.</p>
      </div>
      <% } %>

      <%# ── Invoice header ─────────────────────────────────────────────── %>
      <div class="section-label">Invoice header</div>
      <div class="flex gap-3 flex-wrap items-end mb-8">
        <label class="flex flex-col gap-1">
          Invoice number
          <input type="text" name="number" value="<%= parsed.number || '' %>" required>
        </label>
        <label class="flex flex-col gap-1">
          Receipt date
          <input type="date" name="receiptDate" value="<%= receiptDateInput %>" required>
        </label>
        <label class="flex flex-col gap-1">
          Transaction ID
          <input type="text" name="transactionId" value="<%= parsed.transactionId || '' %>">
        </label>
        <label class="flex flex-col gap-1">
          Total (pence)
          <input type="number" name="totalP" value="<%= parsed.totalP != null ? parsed.totalP : '' %>" required step="1" style="width:9rem;">
        </label>
      </div>

      <%# ── Delivery days ───────────────────────────────────────────────── %>
      <input type="hidden" name="dayCount" value="<%= previewDays.length %>">

      <% previewDays.forEach(function(day, d) { %>
      <input type="hidden" name="day_<%= d %>_itemCount" value="<%= day.lineItems.length %>">

      <div class="section-label">
        Day <%= d + 1 %> &nbsp;·&nbsp;
        <input type="date" name="day_<%= d %>_date" value="<%= day.dateInput %>" required>
      </div>

      <% if (day.lineItems.length === 0) { %>
        <p class="empty-state mb-4">No line items parsed for this day.</p>
      <% } else { %>
      <div class="mb-6">
        <table class="w-full">
          <thead>
            <tr>
              <th style="width:22%">Parsed name</th>
              <th style="width:36%">Product</th>
              <th style="width:20%">Member</th>
              <th class="text-right" style="width:8%">Qty</th>
              <th class="text-right" style="width:10%">Total (p)</th>
              <th class="text-center" style="width:4%">Skip</th>
            </tr>
          </thead>
          <tbody>
            <% day.lineItems.forEach(function(item, i) { %>
            <input type="hidden" name="day_<%= d %>_item_<%= i %>_parsedName" value="<%= item.baseName %>">
            <tr>
              <td class="break-words">
                <% if (item.isAdjustment) { %>
                  <span class="status-badge status-pending" style="font-size:.7em;">ADJ</span>&nbsp;
                <% } %>
                <%= item.name %>
                <% if (!item.matchedId) { %>
                  <br><span class="text-accent text-xs">&#9888; no match — will auto-create</span>
                <% } %>
              </td>
              <td>
                <select name="day_<%= d %>_item_<%= i %>_productId" class="w-full">
                  <option value="">— skip —</option>
                  <% products.forEach(function(p) { %>
                  <option value="<%= p._id %>" <%= item.matchedId === String(p._id) ? 'selected' : '' %>>
                    <%= p.name %><% if (!p.active) { %> (inactive)<% } %>
                  </option>
                  <% }); %>
                </select>
              </td>
              <td>
                <select name="day_<%= d %>_item_<%= i %>_memberId" class="w-full">
                  <option value="">— no rule —</option>
                  <% members.forEach(function(m) { %>
                  <option value="<%= m._id %>" <%= item.preMatchedMemberId === String(m._id) ? 'selected' : '' %>>
                    <%= m.name %>
                  </option>
                  <% }); %>
                </select>
              </td>
              <td class="text-right">
                <input type="number" name="day_<%= d %>_item_<%= i %>_qty" value="<%= item.qty %>" step="0.5" required style="width:4.5rem;text-align:right;">
              </td>
              <td class="text-right">
                <input type="number" name="day_<%= d %>_item_<%= i %>_totalP" value="<%= item.totalP %>" step="1" required style="width:7rem;text-align:right;">
              </td>
              <td class="text-center">
                <input type="checkbox" name="day_<%= d %>_item_<%= i %>_skip">
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
      <% }); %>

      <% if (previewDays.length === 0) { %>
        <p class="empty-state">No delivery days could be parsed from the text.</p>
      <% } %>

      <%# ── Invoice-level charges ───────────────────────────────────────── %>
      <input type="hidden" name="chargeCount" value="<%= parsed.charges.length %>">
      <% if (parsed.charges.length > 0) { %>
      <div class="section-label">Invoice charges</div>
      <div class="mb-6">
        <table class="w-full">
          <thead>
            <tr>
              <th>Type</th>
              <th>Label</th>
              <th class="text-right">Amount (p)</th>
              <th>Split</th>
            </tr>
          </thead>
          <tbody>
            <% parsed.charges.forEach(function(charge, c) { %>
            <input type="hidden" name="charge_<%= c %>_type"    value="<%= charge.type %>">
            <input type="hidden" name="charge_<%= c %>_label"   value="<%= charge.label %>">
            <input type="hidden" name="charge_<%= c %>_amountP" value="<%= charge.amountP %>">
            <tr>
              <td><span class="status-badge status-<%= charge.type === 'discount' ? 'settled' : 'pending' %>"><%= charge.type %></span></td>
              <td><%= charge.label %></td>
              <td class="text-right <%= charge.amountP < 0 ? 'text-settled' : '' %>"><%= charge.amountP %></td>
              <td>
                <select name="charge_<%= c %>_splitType" style="min-width:9rem;">
                  <option value="equal"          <%= charge.splitType === 'equal'          ? 'selected' : '' %>>equal</option>
                  <option value="proportional"   <%= charge.splitType === 'proportional'   ? 'selected' : '' %>>proportional</option>
                  <option value="account-holder" <%= charge.splitType === 'account-holder' ? 'selected' : '' %>>account holder</option>
                </select>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <p class="text-muted text-xs mb-6">
        <strong>equal</strong> — split evenly across all members.
        <strong>proportional</strong> — split in proportion to each member's delivery share (useful for coupons).
        <strong>account holder</strong> — full charge goes to the account holder.
      </p>
      <% } %>

      <%# ── Actions ─────────────────────────────────────────────────────── %>
      <div class="flex gap-4 mt-4 mb-8">
        <button type="submit" class="btn">Create invoice</button>
        <a href="/milkman/invoices/parse" class="btn">Back — re-paste</a>
      </div>

    </form>

    <%# Re-paste without losing context %>
    <details class="mb-16">
      <summary class="cursor-pointer opacity-70 text-[.9em]">Edit raw text and re-parse</summary>
      <form method="POST" action="/milkman/invoices/parse" class="mt-3">
        <textarea name="rawText" rows="12" class="w-full resize-y"><%= rawText %></textarea>
        <br>
        <button type="submit" class="btn mt-2">Re-parse</button>
      </form>
    </details>
  </div>
