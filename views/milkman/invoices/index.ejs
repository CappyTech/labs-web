  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman">Milk·Man</a></div>
      <h1>Invoices</h1>
      <p class="lede">All milk-round invoices.</p>
    </header>

    <div class="flex gap-3 mb-6">
      <a href="/milkman/invoices/new" class="btn">New invoice</a>
      <a href="/milkman/invoices/parse" class="btn">Paste new invoice</a>
    </div>

    <% if (groups.length === 0) { %>
      <p class="empty-state pb-16">No invoices yet.</p>
    <% } else { %>
      <% groups.forEach(function(group) { %>
      <div class="section-label"><%= group.label %></div>
      <section class="card-grid mb-8">
        <% group.invoices.forEach(function(inv) { %>
        <a href="/milkman/invoices/<%= inv.id %>" class="module">
          <div class="callsign"><%= inv.kind === 'membership' ? '[SUB]' : '[INV]' %></div>
          <div class="name"><%= inv.total %></div>
          <div class="desc"><%= inv.receiptDateFormatted %> &nbsp;·&nbsp; #<%= inv.number %></div>
          <div class="host">
            <span class="status-badge status-<%= inv.status %>"><%= inv.status %></span>
          </div>
        </a>
        <% }); %>
      </section>
      <% }); %>
      <div class="pb-8"></div>
    <% } %>
  </div>
