  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman">Milk·Man</a></div>
      <h1>Invoices</h1>
      <p class="lede">All milk-round invoices.</p>
    </header>

    <div style="margin-bottom:1.5rem;">
      <a href="/milkman/invoices/new" class="btn">New invoice</a>
    </div>

    <section class="grid">
      <% if (invoices.length === 0) { %>
        <p class="empty-state">No invoices yet.</p>
      <% } else { %>
        <% invoices.forEach(function(inv) { %>
        <a href="/milkman/invoices/<%= inv.id %>" class="module">
          <div class="callsign">[<%= inv.number %>]</div>
          <div class="name"><%= inv.total %></div>
          <div class="desc"><%= inv.receiptDateFormatted %></div>
          <div class="host">
            <span class="status-badge status-<%= inv.status %>"><%= inv.status %></span>
          </div>
        </a>
        <% }); %>
      <% } %>
    </section>
  </div>
