  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/invoices">Invoices</a></div>
      <h1>Invoice <span class="text-accent">[</span><%= invoice.number %><span class="text-accent">]</span></h1>
      <p class="lede">
        <%= invoice.total %> &nbsp;·&nbsp; <%= invoice.receiptDateFormatted %>
        &nbsp;·&nbsp; <span class="status-badge status-<%= invoice.status %>"><%= invoice.status %></span>
      </p>
    </header>

    <%# ── Delivery days ──────────────────────────────────────────────────── %>
    <% if (invoice.deliveryDays && invoice.deliveryDays.length > 0) { %>
    <div class="section-label">Delivery days</div>
    <% invoice.deliveryDays.forEach(function(day, dayIdx) { %>
    <div class="module mb-6">
      <div class="flex justify-between items-center flex-wrap gap-2">
        <div class="callsign"><%= day.dateFormatted %></div>
        <% if (invoice.status === 'pending') { %>
        <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/delete">
          <button type="submit" class="btn">Remove day</button>
        </form>
        <% } %>
      </div>

      <%# Line items %>
      <% if (day.lineItems && day.lineItems.length > 0) { %>
      <table class="mt-3">
        <thead>
          <tr>
            <th>Product</th>
            <th class="text-right">Qty</th>
            <th class="text-right">Total</th>
            <% if (invoice.status === 'pending') { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% day.lineItems.forEach(function(item, itemIdx) { %>
          <tr>
            <td><%= item.productName %></td>
            <td class="text-right"><%= item.qty %></td>
            <td class="text-right"><%= item.total %></td>
            <% if (invoice.status === 'pending') { %>
            <td class="text-right">
              <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/line-items/<%= itemIdx %>/delete">
                <button type="submit" class="btn">×</button>
              </form>
            </td>
            <% } %>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>

      <%# Add line item form (pending only) %>
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/line-items" class="mt-3">
        <div class="flex gap-2 flex-wrap items-end">
          <label class="flex-1 min-w-[10rem]">
            Product<br>
            <select name="productId" required class="w-full">
              <option value="">— select —</option>
              <% products.forEach(function(p) { %>
              <option value="<%= p._id %>"><%= p.name %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Qty<br>
            <input type="number" name="qty" required step="0.5" min="0" placeholder="1" style="width:5rem;">
          </label>
          <label>
            Total (p)<br>
            <input type="number" name="totalP" required step="1" placeholder="120" style="width:7rem;">
          </label>
          <button type="submit" class="btn">Add item</button>
        </div>
      </form>
      <% } %>

      <%# Communal events %>
      <% if (day.communalEvents && day.communalEvents.length > 0) { %>
      <div class="mt-3">
        <strong class="font-mono text-xs tracking-wide uppercase text-muted">Communal events</strong>
        <% day.communalEvents.forEach(function(evt, evtIdx) { %>
        <div class="flex justify-between items-center gap-2 mt-1">
          <span class="desc"><%= evt.productName %> &times; <%= evt.units %> units — <%= evt.participantNames.join(', ') %></span>
          <% if (invoice.status === 'pending') { %>
          <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/communal-events/<%= evtIdx %>/delete">
            <button type="submit" class="btn">×</button>
          </form>
          <% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <%# Add communal event form (pending only) %>
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/communal-events" class="mt-3">
        <div class="flex flex-col gap-2">
          <div class="flex gap-2 flex-wrap items-end">
            <label class="flex-1 min-w-[10rem]">
              Product<br>
              <select name="productId" required class="w-full">
                <option value="">— select —</option>
                <% products.forEach(function(p) { %>
                <option value="<%= p._id %>"><%= p.name %></option>
                <% }); %>
              </select>
            </label>
            <label>
              Units<br>
              <input type="number" name="units" required min="1" step="1" placeholder="2" style="width:5rem;">
            </label>
          </div>
          <fieldset class="border-0 p-0 m-0">
            <legend class="text-[.85em] mb-1">Participants</legend>
            <div class="flex gap-3 flex-wrap">
              <% members.forEach(function(m) { %>
              <label class="flex items-center gap-1.5 cursor-pointer">
                <input type="checkbox" name="participants" value="<%= m._id %>"> <%= m.name %>
              </label>
              <% }); %>
            </div>
          </fieldset>
          <div><button type="submit" class="btn">Add communal event</button></div>
        </div>
      </form>
      <% } %>
    </div>
    <% }); %>
    <% } %>

    <%# ── Add delivery day (pending only) ───────────────────────────────── %>
    <% if (invoice.status === 'pending') { %>
    <div class="section-label">Add delivery day</div>
    <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days" class="mb-8">
      <div class="flex gap-3 items-end">
        <label>
          Date<br>
          <input type="date" name="date" required>
        </label>
        <button type="submit" class="btn">Add day</button>
      </div>
    </form>
    <% } %>

    <%# ── Charges ───────────────────────────────────────────────────────── %>
    <% if ((invoice.charges && invoice.charges.length > 0) || invoice.status === 'pending') { %>
    <div class="section-label">Charges</div>
    <% } %>
    <% if (invoice.charges && invoice.charges.length > 0) { %>
    <section class="card-grid mb-4">
      <% invoice.charges.forEach(function(charge, chargeIdx) { %>
      <div class="module">
        <div class="callsign">[<%= charge.type.toUpperCase() %>]</div>
        <div class="name"><%= charge.isCredit ? '−' : '+' %><%= charge.amount %></div>
        <div class="desc"><%= charge.label %></div>
        <div class="host"><%= charge.splitType %></div>
        <% if (invoice.status === 'pending') { %>
        <div class="host">
          <form method="POST" action="/milkman/invoices/<%= invoice.id %>/charges/<%= chargeIdx %>/delete">
            <button type="submit" class="btn">Remove</button>
          </form>
        </div>
        <% } %>
      </div>
      <% }); %>
    </section>
    <% } %>

    <% if (invoice.status === 'pending') { %>
    <form method="POST" action="/milkman/invoices/<%= invoice.id %>/charges" class="mb-8 max-w-[40rem]">
      <div class="flex flex-col gap-3">
        <div class="flex gap-2 flex-wrap items-end">
          <label class="flex flex-col gap-1">
            Type
            <select name="type" required>
              <option value="fee">fee</option>
              <option value="discount">discount</option>
              <option value="membership">membership</option>
              <option value="balance">balance</option>
              <option value="other">other</option>
            </select>
          </label>
          <label class="flex-1 min-w-[10rem] flex flex-col gap-1">
            Label
            <input type="text" name="label" required placeholder="e.g. Coupon:FREEMILKHUT">
          </label>
          <label class="flex flex-col gap-1">
            Amount (pence, negative for credits)
            <input type="number" name="amountP" required step="1" placeholder="-1500" style="width:9rem;">
          </label>
          <label class="flex flex-col gap-1">
            Split
            <select name="splitType">
              <option value="equal">equal</option>
              <option value="proportional">proportional</option>
              <option value="account-holder">account holder</option>
            </select>
          </label>
          <button type="submit" class="btn">Add charge</button>
        </div>
      </div>
    </form>
    <% } %>

    <%# ── Adjustments ────────────────────────────────────────────────────── %>
    <% if ((invoice.adjustments && invoice.adjustments.length > 0) || invoice.status === 'pending') { %>
    <div class="section-label">Adjustments</div>
    <% } %>
    <% if (invoice.adjustments && invoice.adjustments.length > 0) { %>
    <section class="card-grid mb-4">
      <% invoice.adjustments.forEach(function(adj, adjIdx) { %>
      <div class="module">
        <div class="callsign"><%= adj.isCredit ? '[CREDIT]' : '[CHARGE]' %></div>
        <div class="name"><%= adj.isCredit ? '−' : '+' %><%= adj.amount %></div>
        <div class="desc"><%= adj.memberName %></div>
        <% if (adj.description) { %><div class="host"><%= adj.description %></div><% } %>
        <% if (invoice.status === 'pending') { %>
        <div class="host">
          <form method="POST" action="/milkman/invoices/<%= invoice.id %>/adjustments/<%= adjIdx %>/delete">
            <button type="submit" class="btn">Remove</button>
          </form>
        </div>
        <% } %>
      </div>
      <% }); %>
    </section>
    <% } %>

    <% if (invoice.status === 'pending') { %>
    <form method="POST" action="/milkman/invoices/<%= invoice.id %>/adjustments" class="mb-8 max-w-[40rem]">
      <div class="flex flex-col gap-3">
        <div class="flex gap-2 flex-wrap items-end">
          <label class="flex-1 min-w-[10rem]">
            Member<br>
            <select name="memberId" required class="w-full">
              <option value="">— select —</option>
              <% members.forEach(function(m) { %>
              <option value="<%= m._id %>"><%= m.name %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Amount (pence, negative for credit)<br>
            <input type="number" name="amountP" required step="1" placeholder="-50" style="width:9rem;">
          </label>
          <label>
            Date<br>
            <input type="date" name="date" required>
          </label>
        </div>
        <div class="flex gap-2 items-end">
          <label class="flex-1">
            Description (optional)<br>
            <input type="text" name="description" placeholder="e.g. Backdated credit from last week" class="w-full">
          </label>
          <button type="submit" class="btn">Add adjustment</button>
        </div>
      </div>
    </form>
    <% } %>

    <%# ── Split result ────────────────────────────────────────────────────── %>
    <% if (settlement) { %>
    <div class="section-label">Split result</div>
    <section class="card-grid mb-8">
      <% settlement.balances.forEach(function(b) { %>
      <div class="module">
        <div class="callsign">[OWES]</div>
        <div class="name"><%= b.owed %></div>
        <div class="desc"><%= b.memberName %></div>
        <% if (b.breakdown && b.breakdown.length > 0) { %>
        <table class="mt-3">
          <tbody>
            <% b.breakdown.forEach(function(e) { %>
            <tr>
              <td><%= e.label %></td>
              <td class="text-muted"><%= e.basis %></td>
              <td class="text-right <%= e.isCredit ? 'text-accent' : '' %>"><%= e.isCredit ? '−' : '' %><%= e.amount %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>
      <% }); %>
    </section>
    <% } %>

    <%# ── Actions ─────────────────────────────────────────────────────────── %>
    <div class="section-label">Actions</div>
    <section class="flex gap-3 flex-wrap mb-16">
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/split">
        <button type="submit" class="btn">Compute split</button>
      </form>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delete">
        <button type="submit" class="btn text-signal">Delete invoice</button>
      </form>
      <% } %>
      <% if (invoice.status === 'computed') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/split">
        <button type="submit" class="btn">Re-compute split</button>
      </form>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/settle">
        <button type="submit" class="btn">Mark settled</button>
      </form>
      <% } %>
    </section>
  </div>
