  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/invoices">Invoices</a></div>
      <h1>Invoice <span class="amp">[</span><%= invoice.number %><span class="amp">]</span></h1>
      <p class="lede">
        <%= invoice.total %> &nbsp;·&nbsp; <%= invoice.receiptDateFormatted %>
        &nbsp;·&nbsp; <span class="status-badge status-<%= invoice.status %>"><%= invoice.status %></span>
      </p>
    </header>

    <%# ── Delivery days ──────────────────────────────────────────────────── %>
    <% if (invoice.deliveryDays && invoice.deliveryDays.length > 0) { %>
    <div class="index-label">Delivery days</div>
    <% invoice.deliveryDays.forEach(function(day, dayIdx) { %>
    <div class="module" style="display:block;margin-bottom:1.5rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem;">
        <div class="callsign"><%= day.dateFormatted %></div>
        <% if (invoice.status === 'pending') { %>
        <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/delete">
          <button type="submit" class="btn">Remove day</button>
        </form>
        <% } %>
      </div>

      <%# Line items %>
      <% if (day.lineItems && day.lineItems.length > 0) { %>
      <table style="width:100%;border-collapse:collapse;margin-top:.75rem;">
        <thead>
          <tr>
            <th style="text-align:left;padding:.25rem .5rem;">Product</th>
            <th style="text-align:right;padding:.25rem .5rem;">Qty</th>
            <th style="text-align:right;padding:.25rem .5rem;">Total</th>
            <% if (invoice.status === 'pending') { %><th></th><% } %>
          </tr>
        </thead>
        <tbody>
          <% day.lineItems.forEach(function(item, itemIdx) { %>
          <tr>
            <td style="padding:.25rem .5rem;"><%= item.productName %></td>
            <td style="text-align:right;padding:.25rem .5rem;"><%= item.qty %></td>
            <td style="text-align:right;padding:.25rem .5rem;"><%= item.total %></td>
            <% if (invoice.status === 'pending') { %>
            <td style="padding:.25rem .5rem;">
              <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/line-items/<%= itemIdx %>/delete">
                <button type="submit" class="btn">×</button>
              </form>
            </td>
            <% } %>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>

      <%# Add line item form (pending only) %>
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/line-items" style="margin-top:.75rem;">
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end;">
          <label style="flex:1;min-width:10rem;">
            Product<br>
            <select name="productId" required style="padding:.35rem .5rem;width:100%;">
              <option value="">— select —</option>
              <% products.forEach(function(p) { %>
              <option value="<%= p._id %>"><%= p.name %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Qty<br>
            <input type="number" name="qty" required step="0.5" min="0" placeholder="1" style="padding:.35rem .5rem;width:5rem;">
          </label>
          <label>
            Total (p)<br>
            <input type="number" name="totalP" required step="1" placeholder="120" style="padding:.35rem .5rem;width:7rem;">
          </label>
          <button type="submit" class="btn">Add item</button>
        </div>
      </form>
      <% } %>

      <%# Communal events %>
      <% if (day.communalEvents && day.communalEvents.length > 0) { %>
      <div style="margin-top:.75rem;">
        <strong>Communal events</strong>
        <% day.communalEvents.forEach(function(evt, evtIdx) { %>
        <div style="display:flex;justify-content:space-between;align-items:center;gap:.5rem;margin-top:.25rem;">
          <span class="desc"><%= evt.productName %> &times; <%= evt.units %> units — <%= evt.participantNames.join(', ') %></span>
          <% if (invoice.status === 'pending') { %>
          <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/communal-events/<%= evtIdx %>/delete">
            <button type="submit" class="btn">×</button>
          </form>
          <% } %>
        </div>
        <% }); %>
      </div>
      <% } %>

      <%# Add communal event form (pending only) %>
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days/<%= dayIdx %>/communal-events" style="margin-top:.75rem;">
        <div style="display:flex;flex-direction:column;gap:.5rem;">
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end;">
            <label style="flex:1;min-width:10rem;">
              Product<br>
              <select name="productId" required style="padding:.35rem .5rem;width:100%;">
                <option value="">— select —</option>
                <% products.forEach(function(p) { %>
                <option value="<%= p._id %>"><%= p.name %></option>
                <% }); %>
              </select>
            </label>
            <label>
              Units<br>
              <input type="number" name="units" required min="1" step="1" placeholder="2" style="padding:.35rem .5rem;width:5rem;">
            </label>
          </div>
          <fieldset style="border:none;padding:0;margin:0;">
            <legend style="font-size:.85em;margin-bottom:.25rem;">Participants</legend>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
              <% members.forEach(function(m) { %>
              <label style="display:flex;align-items:center;gap:.3rem;">
                <input type="checkbox" name="participants" value="<%= m._id %>"> <%= m.name %>
              </label>
              <% }); %>
            </div>
          </fieldset>
          <div><button type="submit" class="btn">Add communal event</button></div>
        </div>
      </form>
      <% } %>
    </div>
    <% }); %>
    <% } %>

    <%# ── Add delivery day (pending only) ───────────────────────────────── %>
    <% if (invoice.status === 'pending') { %>
    <div class="index-label">Add delivery day</div>
    <form method="POST" action="/milkman/invoices/<%= invoice.id %>/delivery-days" style="margin-bottom:2rem;">
      <div style="display:flex;gap:.75rem;align-items:flex-end;">
        <label>
          Date<br>
          <input type="date" name="date" required style="padding:.4rem .6rem;">
        </label>
        <button type="submit" class="btn">Add day</button>
      </div>
    </form>
    <% } %>

    <%# ── Adjustments ────────────────────────────────────────────────────── %>
    <% if ((invoice.adjustments && invoice.adjustments.length > 0) || invoice.status === 'pending') { %>
    <div class="index-label">Adjustments</div>
    <% } %>
    <% if (invoice.adjustments && invoice.adjustments.length > 0) { %>
    <section class="grid" style="margin-bottom:1rem;">
      <% invoice.adjustments.forEach(function(adj, adjIdx) { %>
      <div class="module">
        <div class="callsign"><%= adj.isCredit ? '[CREDIT]' : '[CHARGE]' %></div>
        <div class="name"><%= adj.isCredit ? '−' : '+' %><%= adj.amount %></div>
        <div class="desc"><%= adj.memberName %></div>
        <% if (adj.description) { %><div class="host"><%= adj.description %></div><% } %>
        <% if (invoice.status === 'pending') { %>
        <div class="host">
          <form method="POST" action="/milkman/invoices/<%= invoice.id %>/adjustments/<%= adjIdx %>/delete">
            <button type="submit" class="btn">Remove</button>
          </form>
        </div>
        <% } %>
      </div>
      <% }); %>
    </section>
    <% } %>

    <% if (invoice.status === 'pending') { %>
    <form method="POST" action="/milkman/invoices/<%= invoice.id %>/adjustments" style="margin-bottom:2rem;max-width:40rem;">
      <div style="display:flex;flex-direction:column;gap:.75rem;">
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end;">
          <label style="flex:1;min-width:10rem;">
            Member<br>
            <select name="memberId" required style="padding:.35rem .5rem;width:100%;">
              <option value="">— select —</option>
              <% members.forEach(function(m) { %>
              <option value="<%= m._id %>"><%= m.name %></option>
              <% }); %>
            </select>
          </label>
          <label>
            Amount (pence, negative for credit)<br>
            <input type="number" name="amountP" required step="1" placeholder="-50" style="padding:.35rem .5rem;width:9rem;">
          </label>
          <label>
            Date<br>
            <input type="date" name="date" required style="padding:.35rem .5rem;">
          </label>
        </div>
        <div style="display:flex;gap:.5rem;align-items:flex-end;">
          <label style="flex:1;">
            Description (optional)<br>
            <input type="text" name="description" placeholder="e.g. Backdated credit from last week" style="padding:.35rem .5rem;width:100%;">
          </label>
          <button type="submit" class="btn">Add adjustment</button>
        </div>
      </div>
    </form>
    <% } %>

    <%# ── Split result ────────────────────────────────────────────────────── %>
    <% if (settlement) { %>
    <div class="index-label">Split result</div>
    <section class="grid" style="margin-bottom:2rem;">
      <% settlement.balances.forEach(function(b) { %>
      <div class="module">
        <div class="callsign">[OWES]</div>
        <div class="name"><%= b.owed %></div>
        <div class="desc"><%= b.memberName %></div>
      </div>
      <% }); %>
    </section>
    <% } %>

    <%# ── Actions ─────────────────────────────────────────────────────────── %>
    <div class="index-label">Actions</div>
    <section style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;">
      <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/split">
        <button type="submit" class="btn">Compute split</button>
      </form>
      <% } %>
      <% if (invoice.status === 'computed') { %>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/split">
        <button type="submit" class="btn">Re-compute split</button>
      </form>
      <form method="POST" action="/milkman/invoices/<%= invoice.id %>/settle">
        <button type="submit" class="btn">Mark settled</button>
      </form>
      <% } %>
    </section>
  </div>
