  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman">Milk·Man</a></div>
      <h1>Allocation Rules</h1>
      <p class="lede">Define who pays for each product.</p>
    </header>

    <div class="section-label">Add rule</div>
    <form method="POST" action="/milkman/rules" class="mb-8 max-w-[40rem]">
      <div class="flex flex-col gap-3">
        <div class="flex gap-3 flex-wrap items-end">
          <label class="flex flex-col gap-1">
            Product
            <select name="productId" required>
              <option value="">— select —</option>
              <% products.forEach(function(p) { %>
              <option value="<%= p._id %>"><%= p.name %></option>
              <% }); %>
            </select>
          </label>
          <label class="flex flex-col gap-1">
            Member
            <select name="memberId" required>
              <option value="">— select —</option>
              <% members.forEach(function(m) { %>
              <option value="<%= m._id %>"><%= m.name %></option>
              <% }); %>
            </select>
          </label>
          <label class="flex flex-col gap-1">
            Type
            <select name="type" required>
              <option value="WHOLE">WHOLE — full line to this member</option>
              <option value="FRACTION">FRACTION — share of line</option>
              <option value="FIXED">FIXED — fixed quantity</option>
            </select>
          </label>
        </div>
        <div class="flex gap-3 flex-wrap items-end">
          <label class="flex flex-col gap-1">
            Fraction (FRACTION only, 0–1)
            <input type="number" name="fraction" min="0" max="1" step="0.01" placeholder="e.g. 0.5" style="width:10rem;">
          </label>
          <label class="flex flex-col gap-1">
            Fixed qty (FIXED only)
            <input type="number" name="fixedQty" min="0" step="0.5" placeholder="e.g. 2" style="width:10rem;">
          </label>
          <button type="submit" class="btn">Add rule</button>
        </div>
      </div>
    </form>

    <div class="section-label">Current rules</div>
    <% if (groupedRules.length === 0) { %>
      <p class="empty-state pb-16">No rules yet.</p>
    <% } else { %>
      <% groupedRules.forEach(function(group) { %>
      <div class="section-label" style="font-size:.75em;opacity:.6;"><%= group.name %></div>
      <section class="card-grid mb-4">
        <% group.rules.forEach(function(rule) { %>
        <div class="module">
          <div class="callsign">[<%= rule.type %>]</div>
          <div class="name"><%= rule.member.name %></div>
          <% if (rule.type === 'FRACTION') { %>
          <div class="desc"><%= (rule.fraction * 100).toFixed(0) %>%</div>
          <% } else if (rule.type === 'FIXED') { %>
          <div class="desc">qty: <%= rule.fixedQty %></div>
          <% } %>
          <div class="host">
            <form method="POST" action="/milkman/rules/<%= rule._id %>/delete" class="inline">
              <button type="submit" class="btn">Remove</button>
            </form>
          </div>
        </div>
        <% }); %>
      </section>
      <% }); %>
      <div class="pb-16"></div>
    <% } %>
  </div>
