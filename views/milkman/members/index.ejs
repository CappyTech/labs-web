  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman">Milk·Man</a></div>
      <h1>Members</h1>
      <p class="lede">People in the milk round.</p>
    </header>

    <div class="section-label">Add member</div>
    <form method="POST" action="/milkman/members" class="mb-8">
      <div class="flex gap-3 flex-wrap items-end">
        <label class="flex flex-col gap-1">
          Name
          <input type="text" name="name" required placeholder="e.g. Alice">
        </label>
        <label class="flex items-center gap-2 cursor-pointer pb-[6px]">
          <input type="checkbox" name="isBuyer"> Account holder
        </label>
        <button type="submit" class="btn">Add</button>
      </div>
    </form>

    <div class="section-label">All members</div>
    <section class="card-grid pb-16">
      <% if (members.length === 0) { %>
        <p class="empty-state">No members yet.</p>
      <% } else { %>
        <% members.forEach(function(m) { %>
        <a href="/milkman/members/<%= m._id %>" class="module">
          <div class="callsign"><%= m.active ? '[MEMBER]' : '[INACTIVE]' %></div>
          <div class="name"><%= m.name %></div>
          <% if (m.isBuyer) { %><div class="desc">account holder</div><% } %>
        </a>
        <% }); %>
      <% } %>
    </section>
  </div>
