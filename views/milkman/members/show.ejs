  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/members">Members</a></div>
      <h1><%= member.name %></h1>
      <p class="lede">
        <span class="<%= member.active ? 'text-muted' : 'text-accent' %>"><%= member.active ? 'active' : 'inactive' %></span>
        <% if (member.isBuyer) { %>&nbsp;·&nbsp; account holder<% } %>
        <% if (member.memberSince) { %>&nbsp;·&nbsp; <span class="text-muted">since <%= member.memberSince %></span><% } %>
      </p>
    </header>

    <%# ── Summary ─────────────────────────────────────────────────────────── %>
    <section class="card-grid mb-8">
      <div class="module">
        <div class="callsign">[OUTSTANDING]</div>
        <div class="name <%= outstandingP > 0 ? 'text-accent' : 'text-muted' %>"><%= outstanding %></div>
        <% if (pendingCount > 0) { %>
          <div class="desc text-accent">⚠ <%= pendingCount %> pending invoice<%= pendingCount !== 1 ? 's' : '' %> not yet split — may understate</div>
        <% } else { %>
          <div class="desc">currently due</div>
        <% } %>
      </div>
      <div class="module">
        <div class="callsign">[ROLE]</div>
        <div class="name"><%= member.isBuyer ? 'Account holder' : 'Member' %></div>
        <div class="desc"><%= member.isBuyer ? 'pays the milkman' : 'shares the bill' %></div>
      </div>
      <div class="module">
        <div class="callsign">[STATUS]</div>
        <div class="name"><%= member.active ? 'Active' : 'Inactive' %></div>
        <div class="desc"><%= member.active ? 'included in splits' : 'excluded from new splits' %></div>
      </div>
    </section>

    <div class="flex gap-3 mb-8">
      <a href="/milkman/members/<%= member.id %>/edit" class="btn">Edit member</a>
      <a href="/milkman/members" class="btn">Back to members</a>
    </div>

    <%# ── Settlement history ──────────────────────────────────────────────── %>
    <div class="section-label">Settlement history</div>
    <% if (settlements.length === 0) { %>
      <p class="empty-state mb-8">Not part of any settlement yet.</p>
    <% } else { %>
    <div class="module mb-8">
      <table>
        <thead>
          <tr>
            <th>Window</th>
            <th>Cadence</th>
            <th class="text-right">Invoices</th>
            <th class="text-right">Owed</th>
          </tr>
        </thead>
        <tbody>
          <% settlements.forEach(function(s) { %>
          <tr>
            <td><%= s.windowStartFormatted %> – <%= s.windowEndFormatted %></td>
            <td><%= s.cadence %></td>
            <td class="text-right"><%= s.invoiceCount %></td>
            <td class="text-right"><%= s.owed %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>

    <%# ── Invoice involvement ─────────────────────────────────────────────── %>
    <div class="section-label">Invoice involvement</div>
    <% if (involvement.length === 0) { %>
      <p class="empty-state pb-16">No adjustments or communal events for this member.</p>
    <% } else { %>
    <section class="pb-16">
      <% involvement.forEach(function(inv) { %>
      <div class="module mb-6">
        <div class="flex justify-between items-center flex-wrap gap-2">
          <a href="/milkman/invoices/<%= inv.id %>" class="callsign">[<%= inv.number %>]</a>
          <div class="flex items-center gap-2">
            <span class="text-muted"><%= inv.receiptDateFormatted %></span>
            <span class="status-badge status-<%= inv.status %>"><%= inv.status %></span>
          </div>
        </div>

        <% if (inv.adjustments.length > 0) { %>
        <table class="mt-3">
          <thead>
            <tr>
              <th>Adjustment</th>
              <th>Date</th>
              <th class="text-right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% inv.adjustments.forEach(function(a) { %>
            <tr>
              <td><%= a.description || '—' %></td>
              <td><%= a.dateFormatted %></td>
              <td class="text-right <%= a.isCredit ? 'text-accent' : '' %>"><%= a.isCredit ? '−' : '' %><%= a.amount %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>

        <% if (inv.communalEvents.length > 0) { %>
        <table class="mt-3">
          <thead>
            <tr>
              <th>Communal event</th>
              <th>Date</th>
              <th class="text-right">Units</th>
            </tr>
          </thead>
          <tbody>
            <% inv.communalEvents.forEach(function(e) { %>
            <tr>
              <td><%= e.productName %></td>
              <td><%= e.dateFormatted %></td>
              <td class="text-right"><%= e.units %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>
      <% }); %>
    </section>
    <% } %>
  </div>
