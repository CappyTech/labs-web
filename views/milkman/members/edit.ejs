  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman/members">Members</a></div>
      <h1>Edit member</h1>
      <p class="lede"><%= member.name %></p>
    </header>

    <form method="POST" action="/milkman/members/<%= member._id %>" class="max-w-sm">
      <div class="flex flex-col gap-4 pb-16">
        <label class="flex flex-col gap-1">
          Name
          <input type="text" name="name" value="<%= member.name %>" required>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="isBuyer" <%= member.isBuyer ? 'checked' : '' %>> Account holder
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="active" <%= member.active ? 'checked' : '' %>> Active
        </label>
        <div class="flex gap-3">
          <button type="submit" class="btn">Save</button>
          <a href="/milkman/members" class="btn">Cancel</a>
        </div>
      </div>
    </form>
  </div>
