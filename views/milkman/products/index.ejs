  <div class="wrap">
    <header class="hero">
      <div class="eyebrow"><a href="/milkman">Milk·Man</a></div>
      <h1>Products</h1>
      <p class="lede">Items ordered from the milkman.</p>
    </header>

    <div class="section-label">Add product</div>
    <form method="POST" action="/milkman/products" class="mb-8">
      <div class="flex gap-3 flex-wrap items-end">
        <label class="flex flex-col gap-1">
          Name
          <input type="text" name="name" required placeholder="e.g. Semi-skimmed milk">
        </label>
        <label class="flex flex-col gap-1">
          Price (pence)
          <input type="number" name="priceP" required min="0" step="1" placeholder="e.g. 120" style="width:9rem;">
        </label>
        <label class="flex flex-col gap-1">
          Pints/bottle
          <input type="number" name="pintsPerBottle" min="0" step="0.5" placeholder="e.g. 4" style="width:8rem;">
        </label>
        <label class="flex flex-col gap-1">
          Category
          <input type="text" name="category" placeholder="e.g. milk">
        </label>
        <button type="submit" class="btn">Add</button>
      </div>
    </form>

    <div class="section-label">All products</div>
    <section class="card-grid pb-16">
      <% if (products.length === 0) { %>
        <p class="empty-state">No products yet.</p>
      <% } else { %>
        <% products.forEach(function(p) { %>
        <div class="module">
          <div class="callsign"><%= p.active ? '[PRODUCT]' : '[INACTIVE]' %></div>
          <div class="name"><%= p.name %></div>
          <div class="desc">
            <%= Math.floor(p.priceP / 100) %>.<%= String(p.priceP % 100).padStart(2,'0') %>p
            <% if (p.pintsPerBottle) { %>&nbsp;· <%= p.pintsPerBottle %> pints<% } %>
            <% if (p.category) { %>&nbsp;· <%= p.category %><% } %>
          </div>
          <div class="host">
            <a href="/milkman/products/<%= p._id %>/edit" class="btn">Edit</a>
          </div>
        </div>
        <% }); %>
      <% } %>
    </section>
  </div>
